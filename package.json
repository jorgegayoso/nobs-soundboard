{
  "name": "nobs-soundboard",
  "version": "1.0.0",
  "description": "Nob's Soundboard — microphone soundboard with virtual audio cable routing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.nob.soundboard",
    "productName": "Nob's Soundboard",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "icon": "icon.png"
    },
    "linux": {
      "icon": "icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "icon.ico",
      "icon.png",
      "tray-icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.4",
    "koffi": "^2.9.0"
  }
}
